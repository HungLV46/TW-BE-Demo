{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "Twilight Market Services",
  "scripts": {
    "dev": "moleculer-runner --env --repl --hot services",
    "start": "moleculer-runner services",
    "test": "jest --forceExit --runInBand --silent=false",
    "test-services": "jest --detectOpenHandles --forceExit --runInBand --silent=false tests/services",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "build": "docker-compose -f docker/dev.docker-compose.yml build",
    "up": "docker-compose -f docker/dev.docker-compose.yml up -d",
    "down": "docker-compose -f docker/dev.docker-compose.yml down",
    "stop": "docker-compose -f docker/dev.docker-compose.yml stop",
    "format": "prettier-eslint --write \"**/*.{js,md}\"",
    "format-check": "prettier-eslint --list-different \"**/*.{js,md}\""
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "HuangDarkerThanh",
  "repository": "",
  "devDependencies": {
    "@commitlint/cli": "^17.4.1",
    "@commitlint/config-conventional": "^17.4.0",
    "@cosmjs/cli": "^0.31.1",
    "@faker-js/faker": "^7.4.0",
    "eslint": "^8.25.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-import": "^2.17.3",
    "eslint-plugin-jsx-a11y": "^6.2.1",
    "eslint-plugin-react": "^7.13.0",
    "fishery": "^2.2.2",
    "jest": "^29.5.0",
    "jest-cli": "^29.5.0",
    "moleculer-repl": "^0.6.4",
    "prettier-eslint-cli": "^7.1.0",
    "redis": "^4.6.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.142.0",
    "@bull-board/express": "^5.9.2",
    "@cosmjs/amino": "^0.31.1",
    "@cosmjs/cosmwasm-stargate": "^0.31.1",
    "@cosmjs/crypto": "^0.31.1",
    "@cosmjs/encoding": "^0.31.1",
    "@cosmjs/proto-signing": "^0.31.1",
    "@cosmjs/stargate": "^0.31.1",
    "@moleculer/lab": "^0.6.4",
    "ansi-colors": "^4.1.3",
    "avsc": "^5.7.3",
    "cli-progress": "^3.11.2",
    "csv-parser": "^3.0.0",
    "dayjs": "^1.11.5",
    "dotenv": "^16.0.1",
    "firebase-admin": "^11.5.0",
    "google-auth-library": "^8.7.0",
    "i18n": "^0.13.3",
    "ioredis": "^4.2.0",
    "ipfs-http-client": "56.0.0",
    "is-ipfs": "^8.0.1",
    "jaeger-client": "^3.19.0",
    "knex": "^2.2.0",
    "lodash": "^4.17.21",
    "mime": "^3.0.0",
    "module-alias": "^2.2.2",
    "moleculer": "^0.14.18",
    "moleculer-auto-openapi": "^1.1.5",
    "moleculer-bull": "^0.3.1",
    "moleculer-jaeger": "^0.2.3",
    "moleculer-web": "^0.9.1",
    "moment-timezone": "^0.5.33",
    "njwt": "^1.2.0",
    "objection": "^3.0.1",
    "path": "^0.12.7",
    "pg": "^8.8.0",
    "randomstring": "^1.2.1",
    "redlock": "^3.1.2",
    "twitter-api-sdk": "^1.2.1"
  },
  "engines": {
    "node": ">= 8.x.x"
  },
  "_moduleAliases": {
    "@root": ".",
    "@models": "./app/models",
    "@helpers": "./app/helpers",
    "@mixins": "./mixins",
    "@services": "./services",
    "@config": "./config",
    "@tests": "./tests"
  }
}
